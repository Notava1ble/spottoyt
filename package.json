{
  "name": "spottoyt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"bun run dev:api\" \"bun run dev:web\"",
    "dev:api": "bun run --filter @spottoyt/api dev",
    "dev:web": "bun run --filter @spottoyt/web dev",
    "typecheck": "bun run typecheck:shared && bun run typecheck:api && bun run typecheck:web",
    "typecheck:shared": "bun run --filter @spottoyt/shared typecheck",
    "typecheck:api": "bun run --filter @spottoyt/api typecheck",
    "typecheck:web": "bun run --filter @spottoyt/web typecheck",
    "test": "bun run test:shared && bun run test:api && bun run test:web",
    "test:shared": "bun run --filter @spottoyt/shared test",
    "test:api": "bun run --filter @spottoyt/api test",
    "test:web": "bun run --filter @spottoyt/web test",
    "lint": "biome lint .",
    "check": "biome check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.15"
  }
}
